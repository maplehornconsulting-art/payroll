<odoo>
    <data noupdate="0">

        <!-- Record rules: scope by company (multi-company safe) -->

        <record id="l10n_ca_remittance_config_rule_company" model="ir.rule">
            <field name="name">Remittance Config: company scope</field>
            <field name="model_id" ref="model_l10n_ca_remittance_config"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('hr_payroll.group_hr_payroll_manager')), (4, ref('hr_payroll.group_hr_payroll_user'))]"/>
        </record>

        <record id="l10n_ca_remittance_rule_company" model="ir.rule">
            <field name="name">Remittance: company scope</field>
            <field name="model_id" ref="model_l10n_ca_remittance"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('hr_payroll.group_hr_payroll_manager')), (4, ref('hr_payroll.group_hr_payroll_user'))]"/>
        </record>

        <record id="l10n_ca_remittance_line_rule_company" model="ir.rule">
            <field name="name">Remittance Line: company scope</field>
            <field name="model_id" ref="model_l10n_ca_remittance_line"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('hr_payroll.group_hr_payroll_manager')), (4, ref('hr_payroll.group_hr_payroll_user'))]"/>
        </record>

    </data>
</odoo>
