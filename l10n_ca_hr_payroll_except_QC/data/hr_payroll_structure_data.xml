<odoo>
    <!-- Hourly: keep the original xml id so existing employees / contracts
         keep working without a manual data migration. -->
    <record id="hr_payroll_structure_ca_employee_salary" model="hr.payroll.structure">
        <field name="name">Canadian Employee Salary — Hourly</field>
        <field name="type_id" ref="structure_type_employee_ca"/>
        <field name="country_id" ref="base.ca"/>
    </record>

    <record id="hr_payroll_structure_ca_employee_salary_salaried" model="hr.payroll.structure">
        <field name="name">Canadian Employee Salary — Salaried</field>
        <field name="type_id" ref="structure_type_employee_ca_salaried"/>
        <field name="country_id" ref="base.ca"/>
    </record>
</odoo>
