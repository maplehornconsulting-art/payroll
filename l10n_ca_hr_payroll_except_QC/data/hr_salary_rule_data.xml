    <!-- ======================== ONTARIO HEALTH PREMIUM ======================== -->
    <record id="salary_rule_ca_ohp" model="hr.salary.rule">
        <field name="name">Ontario Health Premium</field>
        <field name="code">OHP</field>
        <field name="sequence">26</field>
        <field name="category_id" ref="hr_salary_rule_category_ca_ohp"/>
        <field name="struct_id" ref="hr_payroll_structure_ca_employee_salary"/>
        <field name="condition_select">python</field>
        <field name="condition_python">
province = employee.l10n_ca_province_id.code or 'ON'
result = (province == 'ON')
        </field>
        <field name="amount_select">code</field>
        <!-- Dr 2380 Net Pay Clearing / Cr 2340 Provincial Tax Payable
             OHP is part of provincial tax obligations and is remitted to
             the Ontario Ministry of Finance alongside PROV_TAX. -->
        <field name="account_debit" ref="account_2340"/>
        <field name="account_credit" ref="account_2380"/>
        <field name="amount_python_compute">result = payslip._l10n_ca_compute_ohp(result_rules=result_rules, inputs=inputs, categories=categories, worked_days=worked_days)</field>
    </record>
