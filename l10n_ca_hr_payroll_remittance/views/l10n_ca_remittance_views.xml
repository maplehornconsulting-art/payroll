<odoo>

    <!-- Remittance — form view -->
    <record id="view_l10n_ca_remittance_form" model="ir.ui.view">
        <field name="name">l10n.ca.remittance.form</field>
        <field name="model">l10n.ca.remittance</field>
        <field name="arch" type="xml">
            <form string="Remittance">
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            invisible="state != 'draft'"
                            class="btn-primary"/>
                    <button name="action_open_payment_wizard" type="object" string="Register Payment"
                            invisible="state != 'confirmed'"
                            class="btn-primary"/>
                    <button name="action_generate_lines" type="object" string="Generate Lines"
                            invisible="state != 'draft'"/>
                    <button name="action_export_pd7a_csv" type="object" string="Export PD7A CSV"
                            invisible="remittance_type != 'cra_pd7a'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('paid', 'cancelled')"
                            confirm="Are you sure you want to cancel this remittance?"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,paid"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_report_l10n_ca_remittance_voucher)d" type="action"
                                class="oe_stat_button" icon="fa-print"
                                invisible="state == 'draft'">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Print Voucher</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Remittance">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="remittance_type"/>
                            <field name="period_start"/>
                            <field name="period_end"/>
                            <field name="due_date"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Payment">
                            <field name="total_amount"/>
                            <field name="move_id" readonly="1"/>
                            <field name="payment_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Remittance Lines">
                            <field name="line_ids" readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="account_id"/>
                                    <field name="label"/>
                                    <field name="amount"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </list>
                            </field>
                        </page>
                        <page string="Payslips">
                            <field name="payslip_ids" readonly="state != 'draft'"
                                   domain="[('state', '=', 'done'), ('company_id', '=', company_id)]">
                                <list>
                                    <field name="name"/>
                                    <field name="employee_id"/>
                                    <field name="date_from"/>
                                    <field name="date_to"/>
                                    <field name="net_wage"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Remittance — list view -->
    <record id="view_l10n_ca_remittance_list" model="ir.ui.view">
        <field name="name">l10n.ca.remittance.list</field>
        <field name="model">l10n.ca.remittance</field>
        <field name="arch" type="xml">
            <list string="Remittances" decoration-danger="is_late"
                  decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'paid'">
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="remittance_type"/>
                <field name="period_start"/>
                <field name="period_end"/>
                <field name="due_date"/>
                <field name="total_amount"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'confirmed'"
                       decoration-success="state == 'paid'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="is_late" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- Remittance — kanban view (for late warnings dashboard) -->
    <record id="view_l10n_ca_remittance_kanban" model="ir.ui.view">
        <field name="name">l10n.ca.remittance.kanban</field>
        <field name="model">l10n.ca.remittance</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="remittance_type">
                <field name="name"/>
                <field name="remittance_type"/>
                <field name="due_date"/>
                <field name="total_amount"/>
                <field name="currency_id"/>
                <field name="state"/>
                <field name="is_late"/>
                <templates>
                    <t t-name="card" class="flex-row">
                        <aside>
                            <field name="state" widget="label_selection"
                                   options="{'classes': {'draft': 'info', 'confirmed': 'warning', 'paid': 'success', 'cancelled': 'muted'}}"/>
                        </aside>
                        <main>
                            <div class="o_kanban_record_title">
                                <field name="name"/>
                            </div>
                            <div>
                                Due: <field name="due_date"/>
                                <span t-if="record.is_late.raw_value"
                                      class="badge text-bg-danger ms-2">OVERDUE</span>
                            </div>
                            <div>
                                <field name="total_amount" widget="monetary"/>
                            </div>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Main action -->
    <record id="action_l10n_ca_remittance" model="ir.actions.act_window">
        <field name="name">Remittances</field>
        <field name="res_model">l10n.ca.remittance</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="context">{}</field>
    </record>

    <!-- Late remittances action (for dashboard) -->
    <record id="action_l10n_ca_remittance_late" model="ir.actions.act_window">
        <field name="name">Overdue Remittances</field>
        <field name="res_model">l10n.ca.remittance</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_late', '=', True)]</field>
        <field name="context">{'search_default_is_late': 1}</field>
    </record>

    <!-- This year action -->
    <record id="action_l10n_ca_remittance_this_year" model="ir.actions.act_window">
        <field name="name">This Year's Remittances</field>
        <field name="res_model">l10n.ca.remittance</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_by_type': 1}</field>
    </record>

    <!-- Search view -->
    <record id="view_l10n_ca_remittance_search" model="ir.ui.view">
        <field name="name">l10n.ca.remittance.search</field>
        <field name="model">l10n.ca.remittance</field>
        <field name="arch" type="xml">
            <search string="Remittances">
                <field name="name"/>
                <field name="remittance_type"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="Paid" name="paid" domain="[('state', '=', 'paid')]"/>
                <filter string="Overdue" name="is_late"
                        domain="[('is_late', '=', True)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Type" name="group_by_type" context="{'group_by': 'remittance_type'}"/>
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Company" name="group_by_company" context="{'group_by': 'company_id'}"
                            groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
