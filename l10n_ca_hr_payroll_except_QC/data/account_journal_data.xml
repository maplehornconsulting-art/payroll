<!--
    Default Salary Journal for Canadian payroll posting.

    Type "general" (miscellaneous journal) is required by hr_payroll_account
    for payslip journal entries.

    The _post_init_hook creates an equivalent journal for every additional
    Canadian company (by country_id.code == 'CA') if one with code SAL does
    not already exist.

    noupdate="1" so that administrators can rename or reconfigure the journal
    without losing their changes on module upgrade.
-->
<odoo noupdate="1">

    <record id="account_journal_sal" model="account.journal">
        <field name="name">Salary Journal</field>
        <field name="type">general</field>
        <field name="code">SAL</field>
    </record>

</odoo>
