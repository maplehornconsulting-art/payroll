<odoo>

    <template id="report_remittance_voucher">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Title -->
                        <div class="row">
                            <div class="col-12 text-center mb-4">
                                <h2>
                                    <t t-if="o.remittance_type == 'cra_pd7a'">PD7A Remittance Voucher</t>
                                    <t t-elif="o.remittance_type == 'provincial_eht'">Provincial EHT Remittance Voucher</t>
                                    <t t-elif="o.remittance_type == 'wcb'">WCB Remittance Voucher</t>
                                    <t t-elif="o.remittance_type == 'rrsp'">RRSP Remittance Voucher</t>
                                    <t t-elif="o.remittance_type == 'union_dues'">Union Dues Remittance Voucher</t>
                                    <t t-else="">Remittance Voucher</t>
                                </h2>
                                <p class="text-muted">Canada Revenue Agency — Payroll Deductions</p>
                            </div>
                        </div>

                        <!-- Company and Period Info -->
                        <div class="row mb-3">
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td><strong>Company:</strong></td>
                                        <td><t t-esc="o.company_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Business Number:</strong></td>
                                        <td>
                                            <t t-set="config" t-value="env['l10n.ca.remittance.config'].search([('company_id', '=', o.company_id.id)], limit=1)"/>
                                            <t t-esc="config.cra_business_number or 'N/A'"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td><strong>Period Start:</strong></td>
                                        <td><t t-esc="o.period_start"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Period End:</strong></td>
                                        <td><t t-esc="o.period_end"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Due Date:</strong></td>
                                        <td>
                                            <strong class="text-danger"><t t-esc="o.due_date"/></strong>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>Status:</strong></td>
                                        <td><t t-esc="dict(o._fields['state'].selection).get(o.state, o.state)"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Itemized Breakdown -->
                        <h4>Itemized Deductions</h4>
                        <table class="table table-striped table-sm">
                            <thead>
                                <tr>
                                    <th>Account</th>
                                    <th>Description</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.line_ids" t-as="line">
                                    <tr>
                                        <td><t t-esc="line.account_id.code"/> — <t t-esc="line.account_id.name"/></td>
                                        <td><t t-esc="line.label or ''"/></td>
                                        <td class="text-end">
                                            <t t-esc="line.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr class="border-top">
                                    <td colspan="2"><strong>Total Remittance</strong></td>
                                    <td class="text-end">
                                        <strong>
                                            <t t-esc="o.total_amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </strong>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- Payment Instructions -->
                        <div class="mt-4">
                            <h4>Payment Instructions</h4>
                            <p>Pay this remittance by the due date using one of the following methods:</p>
                            <ul>
                                <li><strong>Online Banking:</strong> Add "CRA (Revenue) — Current Year Tax Return" as a payee, or use your financial institution's CRA bill payment service.</li>
                                <li><strong>My Business Account:</strong> Log in to <em>www.canada.ca/cra-mybusiness</em> and use "Make a Payment".</li>
                                <li><strong>Cheque:</strong> Payable to the "Receiver General for Canada". Write your 15-character Business Number on the cheque.</li>
                                <li><strong>Wire Transfer:</strong> Contact your financial institution. Include BN and tax period.</li>
                            </ul>
                            <p class="text-muted small">
                                <strong>Note:</strong> Late or insufficient remittances are subject to CRA penalties.
                                Threshold 1 and Threshold 2 remitters must remit by their respective accelerated deadlines.
                                Verify amounts against your PD7A prior to submission.
                            </p>
                        </div>

                        <!-- Payslip count -->
                        <div class="mt-3 text-muted small">
                            <em>Based on <t t-esc="len(o.payslip_ids)"/> payslip(s) for
                            <t t-esc="len(o.payslip_ids.mapped('employee_id'))"/> employee(s).</em>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
