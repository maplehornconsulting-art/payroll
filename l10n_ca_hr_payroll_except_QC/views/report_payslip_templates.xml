<odoo>
    <template id="report_payslip_ca_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-if="o.struct_id.country_id.code == 'CA'">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <!-- Header -->
                            <div class="row mb-4">
                                <div class="col-6">
                                    <h4>Pay Slip</h4>
                                    <p>
                                        <strong>Employee:</strong>
                                        <t t-esc="o.employee_id.name"/>
                                    </p>
                                    <p t-if="o.employee_id.l10n_ca_sin">
                                        <strong>SIN:</strong>
                                        XXX XXX <t t-esc="o.employee_id.l10n_ca_sin[-3:]"/>
                                    </p>
                                    <p>
                                        <strong>Province:</strong>
                                        <t t-esc="o.employee_id.l10n_ca_province_id.name or 'N/A'"/>
                                    </p>
                                </div>
                                <div class="col-6 text-right">
                                    <p>
                                        <strong>Pay Period:</strong>
                                        <t t-esc="o.date_from"/> – <t t-esc="o.date_to"/>
                                    </p>
                                    <p>
                                        <strong>Structure:</strong>
                                        <t t-esc="o.struct_id.name"/>
                                    </p>
                                </div>
                            </div>

                            <!-- Earnings -->
                            <div class="row">
                                <div class="col-12">
                                    <h5>Earnings</h5>
                                    <table class="table table-sm table-bordered">
                                        <thead>
                                            <tr>
                                                <th>Description</th>
                                                <th class="text-right">Amount (CAD)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="o.line_ids.filtered(lambda l: l.category_id.code in ('ALW', 'GROSS') and l.appears_on_payslip)" t-as="line">
                                                <tr>
                                                    <td><t t-esc="line.name"/></td>
                                                    <td class="text-right">
                                                        <t t-esc="'{:,.2f}'.format(line.total)"/>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <!-- Deductions -->
                            <div class="row">
                                <div class="col-12">
                                    <h5>Deductions</h5>
                                    <table class="table table-sm table-bordered">
                                        <thead>
                                            <tr>
                                                <th>Description</th>
                                                <th class="text-right">Amount (CAD)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="o.line_ids.filtered(lambda l: l.category_id.code in ('CPP', 'EI', 'FED_TAX', 'PROV_TAX') and l.appears_on_payslip)" t-as="line">
                                                <tr>
                                                    <td><t t-esc="line.name"/></td>
                                                    <td class="text-right">
                                                        <t t-esc="'{:,.2f}'.format(abs(line.total))"/>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <!-- Net Pay -->
                            <div class="row">
                                <div class="col-12">
                                    <table class="table table-sm table-bordered">
                                        <tbody>
                                            <t t-foreach="o.line_ids.filtered(lambda l: l.code == 'NET')" t-as="line">
                                                <tr class="font-weight-bold">
                                                    <td><strong>Net Pay</strong></td>
                                                    <td class="text-right">
                                                        <strong>
                                                            <t t-esc="'{:,.2f}'.format(line.total)"/>
                                                            CAD
                                                        </strong>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <!-- Employer Contributions -->
                            <div class="row mt-4">
                                <div class="col-12">
                                    <h5>Employer Contributions</h5>
                                    <table class="table table-sm table-bordered">
                                        <thead>
                                            <tr>
                                                <th>Description</th>
                                                <th class="text-right">Amount (CAD)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="o.line_ids.filtered(lambda l: l.category_id.code == 'EMPLOYER' and l.appears_on_payslip)" t-as="line">
                                                <tr>
                                                    <td><t t-esc="line.name"/></td>
                                                    <td class="text-right">
                                                        <t t-esc="'{:,.2f}'.format(line.total)"/>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </t>
    </template>
</odoo>
