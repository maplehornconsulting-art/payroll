<odoo>

    <!-- T4A Slip Form View -->
    <record id="view_hr_payroll_t4a_form" model="ir.ui.view">
        <field name="name">hr.payroll.t4a.form</field>
        <field name="model">hr.payroll.t4a</field>
        <field name="arch" type="xml">
            <form string="T4A Slip">
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_send" string="Mark as Sent" type="object"
                            invisible="state != 'confirmed'"/>
                    <button name="action_draft" string="Reset to Draft" type="object"
                            invisible="state not in ('confirmed', 'sent')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,sent"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Recipient Information">
                            <field name="year"/>
                            <field name="recipient_name"/>
                            <field name="recipient_sin"/>
                            <field name="recipient_bn"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="summary_id"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Recipient Address">
                            <field name="recipient_address" nolabel="1"/>
                        </group>
                    </group>
                    <group string="T4A Boxes">
                        <group>
                            <field name="box_016_pension"/>
                            <field name="box_018_lump_sum"/>
                            <field name="box_020_self_employed"/>
                            <field name="box_022_tax_deducted"/>
                        </group>
                        <group>
                            <field name="box_024_annuities"/>
                            <field name="box_028_other"/>
                            <field name="box_048_fees"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- T4A Slip List View -->
    <record id="view_hr_payroll_t4a_list" model="ir.ui.view">
        <field name="name">hr.payroll.t4a.list</field>
        <field name="model">hr.payroll.t4a</field>
        <field name="arch" type="xml">
            <list string="T4A Slips">
                <field name="name"/>
                <field name="year"/>
                <field name="recipient_name"/>
                <field name="recipient_sin"/>
                <field name="box_016_pension"/>
                <field name="box_022_tax_deducted"/>
                <field name="state"/>
                <field name="currency_id" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- T4A Summary Form View -->
    <record id="view_hr_payroll_t4a_summary_form" model="ir.ui.view">
        <field name="name">hr.payroll.t4a.summary.form</field>
        <field name="model">hr.payroll.t4a.summary</field>
        <field name="arch" type="xml">
            <form string="T4A Summary">
                <header>
                    <button name="action_export_xml" string="Export XML" type="object"
                            invisible="state not in ('draft', 'confirmed')" class="oe_highlight"/>
                    <button name="action_confirm" string="Confirm" type="object"
                            invisible="state != 'draft'"/>
                    <button name="action_draft" string="Reset to Draft" type="object"
                            invisible="state != 'confirmed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Summary Information">
                            <field name="year"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Transmitter Information">
                            <field name="transmitter_bn"/>
                            <field name="transmitter_name"/>
                            <field name="contact_name"/>
                            <field name="contact_phone"/>
                            <field name="contact_email"/>
                        </group>
                    </group>
                    <group string="Totals">
                        <group>
                            <field name="total_recipients"/>
                            <field name="total_pension"/>
                            <field name="total_lump_sum"/>
                            <field name="total_self_employed"/>
                        </group>
                        <group>
                            <field name="total_tax_deducted"/>
                            <field name="total_annuities"/>
                            <field name="total_other"/>
                            <field name="total_fees"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="T4A Slips">
                            <field name="t4a_ids">
                                <list>
                                    <field name="recipient_name"/>
                                    <field name="recipient_sin"/>
                                    <field name="box_016_pension"/>
                                    <field name="box_022_tax_deducted"/>
                                    <field name="state"/>
                                    <field name="currency_id" invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- T4A Summary List View -->
    <record id="view_hr_payroll_t4a_summary_list" model="ir.ui.view">
        <field name="name">hr.payroll.t4a.summary.list</field>
        <field name="model">hr.payroll.t4a.summary</field>
        <field name="arch" type="xml">
            <list string="T4A Summaries">
                <field name="name"/>
                <field name="year"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="total_recipients"/>
                <field name="total_pension"/>
                <field name="total_tax_deducted"/>
                <field name="state"/>
                <field name="currency_id" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_hr_payroll_t4a" model="ir.actions.act_window">
        <field name="name">T4A Statements</field>
        <field name="res_model">hr.payroll.t4a</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_hr_payroll_t4a_summary" model="ir.actions.act_window">
        <field name="name">T4A Summary</field>
        <field name="res_model">hr.payroll.t4a.summary</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_hr_payroll_t4a"
              name="T4A Statements"
              parent="menu_hr_payroll_year_end"
              action="action_hr_payroll_t4a"
              sequence="30"/>

    <menuitem id="menu_hr_payroll_t4a_summary"
              name="T4A Summary"
              parent="menu_hr_payroll_year_end"
              action="action_hr_payroll_t4a_summary"
              sequence="35"/>

</odoo>
