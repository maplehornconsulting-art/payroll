<odoo>

    <!-- Dashboard: Owing Now — unpaid/unconfirmed remittances across all types -->
    <record id="action_l10n_ca_remittance_owing" model="ir.actions.act_window">
        <field name="name">Owing Now</field>
        <field name="res_model">l10n.ca.remittance</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'not in', ['paid', 'cancelled'])]</field>
        <field name="context">{'search_default_group_by_type': 1}</field>
    </record>

    <!-- Dashboard menu: Owing Now -->
    <menuitem id="menu_l10n_ca_remittance_owing"
              name="Owing Now"
              parent="menu_hr_payroll_year_end"
              action="action_l10n_ca_remittance_owing"
              sequence="48"/>

</odoo>
