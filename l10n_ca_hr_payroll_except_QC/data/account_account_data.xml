<!--
    Canadian payroll GL accounts for CRA PD7A reconciliation.
    These accounts are created for the default company on fresh install.
    The _post_init_hook creates matching accounts for every additional
    Canadian company (identified by country_id.code == 'CA').

    Numbering follows the l10n_ca scheme:
      2xxx — current liabilities (source deductions payable)
      5xxx — payroll expense

    noupdate="1": accounts are not overwritten on module upgrade so that
    any company-specific customisations (renamed accounts, analytic tags,
    etc.) are preserved.
-->
<odoo noupdate="1">

    <!-- ============================================================
         LIABILITY ACCOUNTS — Source Deductions &amp; Payroll Payables
         ============================================================ -->

    <record id="account_2310" model="account.account">
        <field name="name">CRA Source Deductions Payable — Federal Income Tax</field>
        <field name="code">2310</field>
        <field name="account_type">liability_current</field>
        <field name="reconcile">True</field>
    </record>

    <record id="account_2320" model="account.account">
        <field name="name">CRA Source Deductions Payable — CPP</field>
        <field name="code">2320</field>
        <field name="account_type">liability_current</field>
        <field name="reconcile">True</field>
    </record>

    <record id="account_2321" model="account.account">
        <field name="name">CRA Source Deductions Payable — CPP2</field>
        <field name="code">2321</field>
        <field name="account_type">liability_current</field>
        <field name="reconcile">True</field>
    </record>

    <record id="account_2330" model="account.account">
        <field name="name">CRA Source Deductions Payable — EI</field>
        <field name="code">2330</field>
        <field name="account_type">liability_current</field>
        <field name="reconcile">True</field>
    </record>

    <record id="account_2340" model="account.account">
        <field name="name">Provincial Income Tax Withheld Payable</field>
        <field name="code">2340</field>
        <field name="account_type">liability_current</field>
        <field name="reconcile">True</field>
    </record>

    <!-- Ontario Employer Health Tax (EHT) — employer payroll tax.
         Wire this account to an EHT salary rule when that rule is added. -->
    <record id="account_2350" model="account.account">
        <field name="name">Ontario EHT Payable</field>
        <field name="code">2350</field>
        <field name="account_type">liability_current</field>
        <field name="reconcile">True</field>
    </record>

    <record id="account_2360" model="account.account">
        <field name="name">RRSP Contributions Payable</field>
        <field name="code">2360</field>
        <field name="account_type">liability_current</field>
        <field name="reconcile">True</field>
    </record>

    <record id="account_2370" model="account.account">
        <field name="name">Union Dues Payable</field>
        <field name="code">2370</field>
        <field name="account_type">liability_current</field>
        <field name="reconcile">True</field>
    </record>

    <!-- Net Pay Clearing: credited by GROSS, debited by each EE deduction.
         The remaining credit balance equals the net cash owed to employees.
         Cleared to zero when the bank payment is recorded. -->
    <record id="account_2380" model="account.account">
        <field name="name">Net Pay Clearing</field>
        <field name="code">2380</field>
        <field name="account_type">liability_current</field>
        <field name="reconcile">True</field>
    </record>

    <!-- ============================================================
         EXPENSE ACCOUNTS — Payroll Cost
         ============================================================ -->

    <!-- Primary salaries expense — used by the GROSS rule to debit
         the full gross pay amount. -->
    <record id="account_5410" model="account.account">
        <field name="name">Salaries &amp; Wages Expense</field>
        <field name="code">5410</field>
        <field name="account_type">expense</field>
    </record>

    <!-- Granular leave / overtime expense accounts.  Created here for
         future use; not currently wired to salary rules because the
         GROSS rule already debits 5410 for all earnings components. -->
    <record id="account_5411" model="account.account">
        <field name="name">Paid Time Off Expense</field>
        <field name="code">5411</field>
        <field name="account_type">expense</field>
    </record>

    <record id="account_5412" model="account.account">
        <field name="name">Sick Time Off Expense</field>
        <field name="code">5412</field>
        <field name="account_type">expense</field>
    </record>

    <record id="account_5413" model="account.account">
        <field name="name">Overtime Expense</field>
        <field name="code">5413</field>
        <field name="account_type">expense</field>
    </record>

    <record id="account_5420" model="account.account">
        <field name="name">CPP Employer Contribution Expense</field>
        <field name="code">5420</field>
        <field name="account_type">expense</field>
    </record>

    <record id="account_5421" model="account.account">
        <field name="name">CPP2 Employer Contribution Expense</field>
        <field name="code">5421</field>
        <field name="account_type">expense</field>
    </record>

    <record id="account_5430" model="account.account">
        <field name="name">EI Employer Premium Expense</field>
        <field name="code">5430</field>
        <field name="account_type">expense</field>
    </record>

    <!-- Ontario EHT Expense — employer side.
         Wire to an EHT salary rule when that rule is added. -->
    <record id="account_5440" model="account.account">
        <field name="name">Ontario EHT Expense</field>
        <field name="code">5440</field>
        <field name="account_type">expense</field>
    </record>

</odoo>
