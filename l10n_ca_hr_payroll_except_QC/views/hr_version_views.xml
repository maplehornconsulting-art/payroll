<odoo>
    <record id="hr_employee_view_form_ca_payroll" model="ir.ui.view">
        <field name="name">hr.employee.form.ca.payroll</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr_payroll.payroll_hr_employee_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='payroll_group']" position="inside">
                <group string="Canadian Payroll Settings" name="l10n_ca_payroll_settings">
                    <group>
                        <field name="l10n_ca_cpp_exempt"/>
                        <field name="l10n_ca_ei_exempt"/>
                    </group>
                    <group>
                        <field name="l10n_ca_additional_tax"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
