<odoo>

    <!-- Payment wizard — form -->
    <record id="view_l10n_ca_remittance_payment_wizard_form" model="ir.ui.view">
        <field name="name">l10n.ca.remittance.payment.wizard.form</field>
        <field name="model">l10n.ca.remittance.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Register Remittance Payment">
                <group>
                    <group>
                        <field name="remittance_id" readonly="1"/>
                        <field name="partner_id" readonly="1"/>
                        <field name="amount" readonly="1"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="payment_date"/>
                        <field name="bank_journal_id"/>
                        <field name="payment_reference"/>
                    </group>
                </group>
                <footer>
                    <button name="action_confirm_payment" type="object"
                            string="Confirm Payment" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
