<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.cra.connector</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr_payroll.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Canadian Payroll – CRA Auto-Update" name="l10n_ca_hr_payroll_cra_connector"
                     groups="hr_payroll.group_hr_payroll_manager">
                    <block title="CRA Feed">
                        <setting string="Feed URL"
                                 help="URL of the CRA payroll tax JSON feed. Leave empty to use the default.">
                            <field name="cra_feed_url" placeholder="https://maplehornconsulting-art.github.io/payroll/v1/ca/latest.json"/>
                        </setting>
                        <setting string="GPG Fingerprint"
                                 help="Optional GPG fingerprint to verify feed signature. Requires python-gnupg.">
                            <field name="cra_feed_gpg_fingerprint" placeholder="e.g. ABCD1234EFGH5678"/>
                        </setting>
                        <setting string="Auto-Apply Updates"
                                 help="⚠ When enabled the cron will auto-apply updates without human review. OFF by default.">
                            <field name="cra_feed_auto_apply"/>
                            <div class="text-warning" invisible="not cra_feed_auto_apply">
                                <i class="fa fa-warning"/> Auto-apply is enabled. Ensure a payroll professional reviews CRA changes before each run.
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
