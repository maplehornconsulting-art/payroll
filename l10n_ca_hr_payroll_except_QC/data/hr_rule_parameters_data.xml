    <!-- ======================== PROVINCIAL TAX CONFIG (JSON) ======================== -->
    <!--
        Each province has ONE parameter: l10n_ca_prov_tax_config
        Value is a JSON string containing brackets, BPA, and surtax info
        for ALL provinces. Updated once per year.
        Format: {"XX": {"brackets": [[threshold, rate], ...], "bpa": N, "surtax": [...]}}
        The top bracket uses 0 as threshold (meaning infinity).
