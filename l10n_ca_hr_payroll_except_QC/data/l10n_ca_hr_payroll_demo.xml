<odoo demo="1">
    <!-- Hourly demo employee — uses Canadian Employee — Hourly structure type -->
    <record id="demo_employee_ca" model="hr.employee">
        <field name="name"> Maple</field>
        <field name="country_id" ref="base.ca"/>
        <field name="l10n_ca_sin">123 456 789</field>
        <field name="l10n_ca_td1_claim_code">1</field>
        <field name="wage">25.00</field>
        <field name="structure_type_id" ref="structure_type_employee_ca"/>
        <field name="contract_date_start">2025-01-01</field>
    </record>

    <!-- Salaried demo employee — uses Canadian Employee — Salaried structure type -->
    <record id="demo_employee_ca_salaried" model="hr.employee">
        <field name="name"> Cedar</field>
        <field name="country_id" ref="base.ca"/>
        <field name="l10n_ca_sin">987 654 321</field>
        <field name="l10n_ca_td1_claim_code">1</field>
        <field name="wage">5000.00</field>
        <field name="structure_type_id" ref="structure_type_employee_ca_salaried"/>
        <field name="contract_date_start">2025-01-01</field>
    </record>
</odoo>
